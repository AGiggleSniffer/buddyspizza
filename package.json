{
  "name": "pizza-webiste",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "format": "exec prettier --write .",
    "lint": "eslint",
    "build": "pnpm format && pnpm lint && next build",
